import 'package:flutter/material.dart';
import '../../../core/services/auth_service.dart';

class PremiumScreen extends StatelessWidget {
  const PremiumScreen({super.key});

  @override
  Widget build(BuildContext context) {
    final user = AuthService.instance.currentUser;

    return Scaffold(
      appBar: AppBar(title: const Text('Premium')),
      body: Padding(
        padding: const EdgeInsets.all(16),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            const Text(
              'Upgrade to Premium',
              style: TextStyle(fontSize: 22, fontWeight: FontWeight.bold),
            ),
            const SizedBox(height: 12),
            const Text(
              '• Screenshot & save page as image\n'
              '• TTS listening & auto-scroll\n'
              '• Custom background colors & fonts\n'
              '• Translation to preferred language',
            ),
            const Spacer(),
            ElevatedButton(
              onPressed: () {
                // TODO: open payment options (Google, Apple, Flutterwave)
                ScaffoldMessenger.of(context).showSnackBar(
                  const SnackBar(
                    content: Text('Payment flow not implemented yet.'),
                  ),
                );
              },
              child: const Text('Subscribe with Flutterwave / Store'),
            ),
            const SizedBox(height: 8),
            if (user?.isPremium == true)
              const Text(
                'You are already Premium.',
                style: TextStyle(color: Colors.green),
              ),
          ],
        ),
      ),
    );
  }
}// features/premium/presentation/premium_plus_screen.dart
import 'package:flutter/material.dart';
import '../../../core/services/auth_service.dart';

class PremiumPlusScreen extends StatelessWidget {
  const PremiumPlusScreen({super.key});

  @override
  Widget build(BuildContext context) {
    final user = AuthService.instance.currentUser;

    final isPremium = user?.isPremium ?? false;

    return Scaffold(
      appBar: AppBar(title: const Text('Premium+')),
      body: Padding(
        padding: const EdgeInsets.all(16),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            const Text(
              'Premium+ Creator Tier',
              style: TextStyle(fontSize: 22, fontWeight: FontWeight.bold),
            ),
            const SizedBox(height: 12),
            const Text(
              '• Elite creator perks\n'
              '• Higher earnings\n'
              '• Priority ranking\n'
              '• Yellow+ badge',
            ),
            const Spacer(),
            if (!isPremium)
              const Text(
                'You must be a Premium writer before requesting Premium+.',
                style: TextStyle(color: Colors.red),
              ),
            const SizedBox(height: 8),
            ElevatedButton(
              onPressed: isPremium
                  ? () {
                      // TODO: send Premium+ request to backend
                      ScaffoldMessenger.of(context).showSnackBar(
                        const SnackBar(
                          content: Text('Premium+ request sent (placeholder).'),
                        ),
                      );
                    }
                  : null,
              child: const Text('Request Premium+'),
            ),
          ],
        ),
      ),
    );
  }
}
