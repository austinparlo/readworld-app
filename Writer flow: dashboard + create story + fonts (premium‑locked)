// features/writer/presentation/writer_dashboard_screen.dart
import 'package:flutter/material.dart';
import '../../../core/services/auth_service.dart';
import 'create_story_screen.dart';

class WriterDashboardScreen extends StatelessWidget {
  const WriterDashboardScreen({super.key});

  @override
  Widget build(BuildContext context) {
    final user = AuthService.instance.currentUser;

    return Scaffold(
      appBar: AppBar(
        title: const Text('Writer Dashboard'),
      ),
      body: Padding(
        padding: const EdgeInsets.all(16),
        child: Column(
          children: [
            if (user == null)
              const Text(
                'You must be logged in to become a writer.',
                style: TextStyle(color: Colors.red),
              ),
            const SizedBox(height: 12),
            ElevatedButton.icon(
              onPressed: () {
                Navigator.of(context).push(
                  MaterialPageRoute(
                    builder: (_) => const CreateStoryScreen(),
                  ),
                );
              },
              icon: const Icon(Icons.edit),
              label: const Text('Create new story'),
            ),
            const SizedBox(height: 12),
            ElevatedButton(
              onPressed: () {
                Navigator.of(context).pushNamed('/premium');
              },
              child: const Text('Upgrade to Premium for fonts & tools'),
            ),
          ],
        ),
      ),
    );
  }
}// features/writer/presentation/create_story_screen.dart
import 'package:flutter/material.dart';
import '../../../core/services/auth_service.dart';
import '../widgets/font_picker.dart';

class CreateStoryScreen extends StatefulWidget {
  const CreateStoryScreen({super.key});

  @override
  State<CreateStoryScreen> createState() => _CreateStoryScreenState();
}

class _CreateStoryScreenState extends State<CreateStoryScreen> {
  final _titleController = TextEditingController();
  final _contentController = TextEditingController();
  String? _titleFont;
  String? _bodyFont;

  @override
  Widget build(BuildContext context) {
    final user = AuthService.instance.currentUser;
    final isPremium = user?.isPremium ?? false;

    return Scaffold(
      appBar: AppBar(title: const Text('Create Story')),
      body: Padding(
        padding: const EdgeInsets.all(16),
        child: ListView(
          children: [
            TextField(
              controller: _titleController,
              decoration: const InputDecoration(labelText: 'Title'),
            ),
            const SizedBox(height: 12),
            TextField(
              controller: _contentController,
              decoration: const InputDecoration(labelText: 'Content'),
              maxLines: 10,
            ),
            const SizedBox(height: 16),
            if (isPremium)
              FontPicker(
                onTitleFontChanged: (f) => setState(() => _titleFont = f),
                onBodyFontChanged: (f) => setState(() => _bodyFont = f),
              )
            else
              const Text(
                'Custom fonts are available for Premium writers only.',
                style: TextStyle(color: Colors.orange),
              ),
            const SizedBox(height: 16),
            ElevatedButton(
              onPressed: () {
                // TODO: send story to backend with fonts if premium
                ScaffoldMessenger.of(context).showSnackBar(
                  const SnackBar(
                    content: Text('Story saved (placeholder).'),
                  ),
                );
              },
              child: const Text('Publish'),
            ),
          ],
        ),
      ),
    );
  }
}// features/writer/widgets/font_picker.dart
import 'package:flutter/material.dart';

class FontPicker extends StatelessWidget {
  final ValueChanged<String> onTitleFontChanged;
  final ValueChanged<String> onBodyFontChanged;

  const FontPicker({
    super.key,
    required this.onTitleFontChanged,
    required this.onBodyFontChanged,
  });

  @override
  Widget build(BuildContext context) {
    final fonts = ['Inter', 'PlayfairDisplay', 'Roboto', 'Lora'];

    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        const Text(
          'Title font',
          style: TextStyle(fontWeight: FontWeight.bold),
        ),
        Wrap(
          spacing: 8,
          children: fonts
              .map(
                (f) => ChoiceChip(
                  label: Text(f),
                  selected: false,
                  onSelected: (_) => onTitleFontChanged(f),
                ),
              )
              .toList(),
        ),
        const SizedBox(height: 12),
        const Text(
          'Body font',
          style: TextStyle(fontWeight: FontWeight.bold),
        ),
        Wrap(
          spacing: 8,
          children: fonts
              .map(
                (f) => ChoiceChip(
                  label: Text(f),
                  selected: false,
                  onSelected: (_) => onBodyFontChanged(f),
                ),
              )
              .toList(),
        ),
      ],
    );
  }
}
